# ──────────────────────────────────────────────────────────────────────────
# INOV Holding — backend configuration
# Copy this file to `.env` and fill in real values on the server.
# On Hostinger, set these in the Node.js app's Environment Variables panel.
# ──────────────────────────────────────────────────────────────────────────

# Port the Express server listens on (Hostinger injects PORT automatically).
PORT=4321

# ── Database ────────────────────────────────────────────────────────────────
# Leave DB_HOST empty for local development -> uses a zero-config SQLite file
# (data.sqlite). Set DB_HOST to switch to MySQL (recommended on Hostinger,
# create the database in hPanel -> Databases -> MySQL).
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
# Optional path for the local SQLite file (dev only).
SQLITE_PATH=./data.sqlite

# ── Admin account ───────────────────────────────────────────────────────────
# Bootstrapped into the database on first run. Change the password after login.
ADMIN_EMAIL=admin@inovholding.ao
ADMIN_PASSWORD=change-me-now

# Secret used to sign admin session tokens (use a long random string).
JWT_SECRET=replace-with-a-long-random-string

# ── Email notifications (SMTP) ──────────────────────────────────────────────
# Used to notify the team of new contact messages / job applications.
# On Hostinger, create an email account and use its SMTP settings.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
# "From" address (usually same as SMTP_USER) and where notifications are sent.
MAIL_FROM=geral@inovholding.ao
MAIL_TO=geral@inovholding.ao
